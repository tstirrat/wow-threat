{
  "name": "@wow-threat/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "fmt": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "kv:reset:local": "rm -rf .wrangler/state"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.46.0",
    "@wow-threat/config": "workspace:*",
    "@wow-threat/engine": "workspace:*",
    "@wow-threat/shared": "workspace:*",
    "@wow-threat/wcl-types": "workspace:*",
    "hono": "^4.12.9",
    "jose": "^6.1.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.19",
    "@cloudflare/workers-types": "^4.20260301.1",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.0.1",
    "@eslint/markdown": "^7.5.1",
    "@vitest/coverage-istanbul": "^3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "@wow-threat/typescript-config": "workspace:*",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.2.4",
    "wrangler": "^4.70.0"
  }
}
